void setup()
{
  pinMode(MCP4922_CS_PIN, OUTPUT);
  digitalWrite(MCP4922_CS_PIN, HIGH);
  SPI.begin();
  pinMode(8, OUTPUT);
}


void mcp4922(uint16_t value, uint8_t channel)  //  channel = 0, 1
{
  uint16_t data = 0x3000 | value;
  if (channel == 1) data |= 0x8000;
  digitalWrite(MCP4922_CS_PIN, LOW);
  SPI.beginTransaction(SPISettings(16000000, MSBFIRST, SPI_MODE0));
  SPI.transfer((uint8_t)(data >> 8));
  SPI.transfer((uint8_t)(data & 0xFF));
  SPI.endTransaction();
  digitalWrite(MCP4922_CS_PIN, HIGH);
}



void loop()
{
  digitalWrite(8,1);
  for (int16_t i = 0; i <= 499; i++) {
    mcp4922(s_plus[i]*3 , 0);         // Conversion de 8 bits sur 12 bits
    mcp4922(s_moins[i]*3 , 1);        // Conversion de 8 bits sur 12 bits
    delay(10);                        // R = 1/10ms = 100 kHz
    if (i==0) {
      digitalWrite(8,0);
    }
  }
}

